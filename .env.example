# ============================================================
# vibe-stack — environment variables
# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored and never committed.
# ============================================================

# --- Firebase (Project settings > General > Your apps > SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Claude AI (pick ONE of the two options) ---

# Option A — RECOMMENDED: proxy via a Firebase Function (key stays server-side).
# Set this to the URL of your deployed `claude` function, e.g.:
#   https://us-central1-<project-id>.cloudfunctions.net/claude
# When set, the direct key below is ignored.
VITE_CLAUDE_PROXY_URL=

# Option B — SIMPLE: direct browser call.
# WARNING: this key ships in the browser bundle and is visible to anyone
# who visits the site. Only use a key with tight limits. Leave both empty
# to disable the AI features.
VITE_ANTHROPIC_API_KEY=
